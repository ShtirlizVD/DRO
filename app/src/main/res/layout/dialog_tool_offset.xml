<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/bg_darker"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Смещения координат"
        android:textColor="@color/text_dim"
        android:textSize="12sp"
        android:gravity="center" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="4dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="X"
                android:textColor="@color/coord_x"
                android:textSize="14sp"
                android:gravity="center" />

            <EditText
                android:id="@+id/et_offset_x"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberSigned|numberDecimal"
                android:text="0.000"
                android:textColor="@color/text_bright"
                android:gravity="center"
                android:background="@color/button_bg"
                android:padding="8dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="4dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="D"
                android:textColor="@color/coord_d"
                android:textSize="14sp"
                android:gravity="center" />

            <EditText
                android:id="@+id/et_offset_d"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberSigned|numberDecimal"
                android:text="0.000"
                android:textColor="@color/text_bright"
                android:gravity="center"
                android:background="@color/button_bg"
                android:padding="8dp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="4dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Z"
                android:textColor="@color/coord_z"
                android:textSize="14sp"
                android:gravity="center" />

            <EditText
                android:id="@+id/et_offset_z"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberSigned|numberDecimal"
                android:text="0.000"
                android:textColor="@color/text_bright"
                android:gravity="center"
                android:background="@color/button_bg"
                android:padding="8dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="4dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="L"
                android:textColor="@color/coord_l"
                android:textSize="14sp"
                android:gravity="center" />

            <EditText
                android:id="@+id/et_offset_l"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberSigned|numberDecimal"
                android:text="0.000"
                android:textColor="@color/text_bright"
                android:gravity="center"
                android:background="@color/button_bg"
                android:padding="8dp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
