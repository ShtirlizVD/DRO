<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp"
    android:gravity="center_vertical"
    android:background="?android:attr/selectableItemBackground">

    <!-- Thread Name -->
    <TextView
        android:id="@+id/tv_thread_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="M10"
        android:textColor="@color/text_bright"
        android:textSize="16sp"
        android:textStyle="bold" />

    <!-- Diameter -->
    <TextView
        android:id="@+id/tv_thread_diameter"
        android:layout_width="80dp"
        android:layout_height="wrap_content"
        android:text="10.0"
        android:textColor="@color/coord_l"
        android:textSize="14sp"
        android:gravity="center" />

    <!-- Pitch -->
    <TextView
        android:id="@+id/tv_thread_pitch"
        android:layout_width="70dp"
        android:layout_height="wrap_content"
        android:text="1.500"
        android:textColor="@color/coord_x"
        android:textSize="14sp"
        android:gravity="center" />

    <!-- Depth -->
    <TextView
        android:id="@+id/tv_thread_depth"
        android:layout_width="70dp"
        android:layout_height="wrap_content"
        android:text="0.920"
        android:textColor="@color/coord_z"
        android:textSize="14sp"
        android:gravity="center" />

    <!-- Passes -->
    <TextView
        android:id="@+id/tv_thread_passes"
        android:layout_width="50dp"
        android:layout_height="wrap_content"
        android:text="11"
        android:textColor="@color/coord_d"
        android:textSize="14sp"
        android:gravity="center" />

</LinearLayout>
