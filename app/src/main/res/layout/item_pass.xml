<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp"
    android:gravity="center_vertical"
    android:background="@drawable/pass_item_selector">

    <!-- Pass Number -->
    <TextView
        android:id="@+id/tv_pass_number"
        android:layout_width="40dp"
        android:layout_height="wrap_content"
        android:text="1"
        android:textColor="@color/text_bright"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center" />

    <!-- Depth Increment -->
    <TextView
        android:id="@+id/tv_depth_inc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="0.150"
        android:textColor="@color/coord_x"
        android:textSize="15sp"
        android:gravity="center" />

    <!-- Total Depth -->
    <TextView
        android:id="@+id/tv_total_depth"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="0.150"
        android:textColor="@color/coord_z"
        android:textSize="15sp"
        android:gravity="center" />

    <!-- Target Diameter -->
    <TextView
        android:id="@+id/tv_diameter"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="9.700"
        android:textColor="@color/coord_d"
        android:textSize="15sp"
        android:gravity="center" />

    <!-- Status Indicator -->
    <ImageView
        android:id="@+id/iv_status"
        android:layout_width="50dp"
        android:layout_height="28dp"
        android:gravity="center"
        android:src="@android:drawable/checkbox_off_background" />

</LinearLayout>
