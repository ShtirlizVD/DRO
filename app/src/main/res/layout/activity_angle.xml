<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@color/bg_dark"
    android:padding="8dp">

    <!-- Left Panel - compact -->
    <LinearLayout
        android:layout_width="220dp"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Current Position - large, two rows -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/bg_darker"
            android:padding="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="X: "
                    android:textColor="@color/coord_x"
                    android:textSize="35sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_current_x"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0.000"
                    android:textColor="@color/text_bright"
                    android:textSize="35sp"
                    android:textStyle="bold"
                    android:textAlignment="textEnd"
                    android:gravity="end" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Z: "
                    android:textColor="@color/coord_z"
                    android:textSize="35sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_current_z"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0.000"
                    android:textColor="@color/text_bright"
                    android:textSize="35sp"
                    android:textStyle="bold"
                    android:textAlignment="textEnd"
                    android:gravity="end" />
            </LinearLayout>
        </LinearLayout>

        <!-- Angle Results - large -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="6dp"
            android:background="@color/bg_darker"
            android:padding="8dp">

            <!-- Angle Z -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_label_angle_z"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Угол Z"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/tv_angle_z"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:lineSpacingMultiplier="0.9"
                    android:text="—°"
                    android:textSize="61sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Angle X -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="4dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tv_label_angle_x"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Угол X"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/tv_angle_x"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—°"
                    android:textSize="61sp"
                    android:textStyle="bold"
                    android:includeFontPadding="false"
                    android:lineSpacingMultiplier="0.9" />
            </LinearLayout>
        </LinearLayout>

        <!-- Start Point Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@color/bg_darker"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/start_point"
                android:textColor="#4CAF50"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="20dp"
                    android:layout_height="wrap_content"
                    android:text="@string/coord_x"
                    android:textColor="@color/coord_x"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/tv_start_x"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="—"
                    android:textColor="@color/text_bright"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="20dp"
                    android:layout_height="wrap_content"
                    android:text="@string/coord_z"
                    android:textColor="@color/coord_z"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/tv_start_z"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="—"
                    android:textColor="@color/text_bright"
                    android:textSize="18sp"
                    android:gravity="start" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_set_start"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/button_tool"
                android:text="Установить точку"
                android:textColor="@color/text_bright"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Taper Results -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="6dp"
            android:background="@color/bg_darker"
            android:padding="8dp">

            <!-- Taper Z -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tv_label_taper_z"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Конус Z"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/tv_taper_z"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="61sp"
                    android:textStyle="bold"
                    android:includeFontPadding="false"
                    android:lineSpacingMultiplier="0.9" />
            </LinearLayout>

            <!-- Taper X -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="4dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tv_label_taper_x"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Конус X"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/tv_taper_x"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="61sp"
                    android:textStyle="bold"
                    android:includeFontPadding="false"
                    android:lineSpacingMultiplier="0.9" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Close Button -->
        <Button
            android:id="@+id/btn_close"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Закрыть"
            android:textSize="20sp"
            android:textColor="@color/text_bright"
            android:background="@drawable/button_menu" />
    </LinearLayout>

    <!-- Right Panel: Angle Visualization -->
    <com.dro.lathe.AngleView
        android:id="@+id/angle_view"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:layout_marginStart="6dp"
        android:background="@color/bg_darker" />

</LinearLayout>
