<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <Button
            android:id="@+id/btn_back"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="← Назад"
            android:textColor="@color/text_bright"
            android:background="@drawable/button_menu"
            android:layout_marginBottom="16dp" />

        <!-- Device Info -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Устройство Bluetooth"
            android:textColor="@color/text_bright"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_device"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Не выбрано"
            android:textColor="@color/text_dim"
            android:textSize="16sp"
            android:padding="12dp"
            android:background="@color/button_bg"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/button_border"
            android:layout_marginVertical="8dp" />

        <!-- Resolution X -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Разрешение линейки X (поперечная)"
            android:textColor="@color/text_bright"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/spinner_resolution_x"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp"
            android:background="@color/button_bg" />

        <!-- Resolution Z -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Разрешение линейки Z (продольная)"
            android:textColor="@color/text_bright"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp" />

        <Spinner
            android:id="@+id/spinner_resolution_z"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp"
            android:background="@color/button_bg" />

        <!-- Sound -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Звуковой сигнал"
                android:textColor="@color/text_bright"
                android:textSize="16sp" />

            <Switch
                android:id="@+id/switch_sound"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Proximity -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Зона приближения к засечкам"
            android:textColor="@color/text_bright"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <SeekBar
                android:id="@+id/seek_proximity"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progress="5" />

            <TextView
                android:id="@+id/tv_proximity"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="5 мм"
                android:textColor="@color/text_bright"
                android:textSize="14sp"
                android:gravity="end" />
        </LinearLayout>

        <!-- Hint -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Двойной клик на X переключает режим диаметр/радиус.\nДолгое нажатие на число меняет цвет."
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            android:layout_marginTop="32dp"
            android:gravity="center" />

    </LinearLayout>
</ScrollView>
