<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/dialog_background"
    android:padding="24dp"
    android:gravity="center">

    <!-- Заголовок -->
    <TextView
        android:id="@+id/dialog_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Диаметр"
        android:textColor="#FFFFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="8dp" />

    <!-- Было: значение -->
    <TextView
        android:id="@+id/tv_current_value"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Было: 000.000"
        android:textColor="#FF808080"
        android:textSize="18sp"
        android:gravity="center"
        android:paddingBottom="12dp" />

    <!-- Поле ввода - БОЛЬШОЕ 120dp высота, шрифт 72sp -->
    <EditText
        android:id="@+id/et_value"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:inputType="numberDecimal|numberSigned"
        android:text=""
        android:textColor="#FFFFFFFF"
        android:textSize="72sp"
        android:textStyle="bold"
        android:gravity="center"
        android:fontFamily="monospace"
        android:includeFontPadding="false"
        android:background="@drawable/input_field_background"
        android:padding="0dp"
        android:hint="0.000"
        android:textColorHint="#FF505050"
        android:selectAllOnFocus="true"
        android:maxLines="1" />

    <!-- Кнопки: Отмена - ZERO - OK -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp"
        android:gravity="center">

        <Button
            android:id="@+id/btn_cancel"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="Отмена"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FF808080"
            android:background="@drawable/button_cancel" />

        <!-- Кнопка ZERO посередине -->
        <Button
            android:id="@+id/btn_preset_0"
            android:layout_width="100dp"
            android:layout_height="64dp"
            android:layout_marginHorizontal="6dp"
            android:text="ZERO"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF00"
            android:background="@drawable/button_yellow" />

        <Button
            android:id="@+id/btn_ok"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="OK"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFFFF"
            android:background="@drawable/button_ok" />
    </LinearLayout>

</LinearLayout>
