<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/dialog_background"
    android:padding="24dp">

    <!-- Заголовок -->
    <TextView
        android:id="@+id/dialog_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Диаметр"
        android:textColor="@color/text_bright"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="16dp" />

    <!-- Текущее значение (показываем что было) -->
    <TextView
        android:id="@+id/tv_current_value"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Было: 000.000"
        android:textColor="@color/text_dim"
        android:textSize="18sp"
        android:gravity="center"
        android:paddingBottom="12dp" />

    <!-- Поле ввода - ОГРОМНОЕ и ЯРКОЕ -->
    <EditText
        android:id="@+id/et_value"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:inputType="numberDecimal|numberSigned"
        android:text=""
        android:textColor="@color/text_bright"
        android:textSize="48sp"
        android:textStyle="bold"
        android:gravity="center"
        android:fontFamily="monospace"
        android:background="@drawable/input_field_background"
        android:padding="12dp"
        android:hint="0.000"
        android:textColorHint="#FF505050"
        android:selectAllOnFocus="true" />

    <!-- Быстрые кнопки ввода -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        android:gravity="center">

        <Button
            android:id="@+id/btn_preset_0"
            style="@style/PresetButton"
            android:text="0" />

        <Button
            android:id="@+id/btn_preset_10"
            style="@style/PresetButton"
            android:text="10" />

        <Button
            android:id="@+id/btn_preset_20"
            style="@style/PresetButton"
            android:text="20" />

        <Button
            android:id="@+id/btn_preset_50"
            style="@style/PresetButton"
            android:text="50" />

        <Button
            android:id="@+id/btn_preset_100"
            style="@style/PresetButton"
            android:text="100" />
    </LinearLayout>

    <!-- Кнопки ОК и Отмена -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp">

        <Button
            android:id="@+id/btn_cancel"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Отмена"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_dim"
            android:background="@drawable/button_cancel" />

        <Button
            android:id="@+id/btn_ok"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="OK"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_bright"
            android:background="@drawable/button_ok" />
    </LinearLayout>

</LinearLayout>
