<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    android:padding="12dp">

    <!-- Header: Thread Name and Type -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/tv_thread_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="M10"
            android:textColor="@color/text_bright"
            android:textSize="28sp"
            android:textStyle="bold" />

        <!-- Thread Type Toggle -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/button_tool">

            <Button
                android:id="@+id/btn_external"
                android:layout_width="80dp"
                android:layout_height="36dp"
                android:text="Наруж."
                android:textSize="11sp"
                android:background="@drawable/button_tool" />

            <Button
                android:id="@+id/btn_internal"
                android:layout_width="80dp"
                android:layout_height="36dp"
                android:text="Внутр."
                android:textSize="11sp"
                android:background="@drawable/button_tool" />
        </LinearLayout>
    </LinearLayout>

    <!-- Thread Parameters Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_darker"
        android:padding="10dp"
        android:layout_marginBottom="8dp">

        <!-- Row 1: Pitch and Depth -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Шаг"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tv_pitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1.500 мм"
                    android:textColor="@color/coord_x"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Глубина"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tv_depth"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.920 мм"
                    android:textColor="@color/coord_z"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Проходов"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tv_passes_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="11"
                    android:textColor="@color/coord_d"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Row 2: Diameters -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Начальный диам."
                    android:textColor="@color/text_dim"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tv_start_diameter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10.000"
                    android:textColor="@color/text_bright"
                    android:textSize="16sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Конечный диам."
                    android:textColor="@color/text_dim"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tv_final_diameter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="8.160"
                    android:textColor="@color/text_bright"
                    android:textSize="16sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Отверстие"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tv_tap_drill"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="8.500"
                    android:textColor="@color/text_bright"
                    android:textSize="16sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Progress Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="4dp"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Прогресс:"
            android:textColor="@color/text_dim"
            android:textSize="12sp" />

        <ProgressBar
            android:id="@+id/progress_bar"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="16dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:progressTint="@color/coord_x"
            android:progressBackgroundTint="@color/button_border" />

        <TextView
            android:id="@+id/tv_progress_percent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0%"
            android:textColor="@color/coord_x"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Passes List Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="6dp"
        android:background="@color/bg_darker">

        <TextView
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="#"
            android:textColor="@color/text_dim"
            android:textSize="11sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Глубина"
            android:textColor="@color/text_dim"
            android:textSize="11sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Сумма"
            android:textColor="@color/text_dim"
            android:textSize="11sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Диаметр"
            android:textColor="@color/text_dim"
            android:textSize="11sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:text="Статус"
            android:textColor="@color/text_dim"
            android:textSize="11sp"
            android:textStyle="bold"
            android:gravity="center" />
    </LinearLayout>

    <!-- Passes List -->
    <ListView
        android:id="@+id/passes_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/bg_darker"
        android:divider="@color/button_border"
        android:dividerHeight="1dp" />

    <!-- Bottom Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <Button
            android:id="@+id/btn_reset"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Сброс"
            android:textColor="@color/text_bright"
            android:background="@drawable/button_cancel"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btn_close"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Закрыть"
            android:textColor="@color/text_bright"
            android:background="@drawable/button_menu"
            android:layout_marginStart="4dp" />
    </LinearLayout>

</LinearLayout>
