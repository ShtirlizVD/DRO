<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <bitmap android:src="@drawable/ic_zero" />
            </item>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="12dp"/>
                    <stroke android:width="3dp" android:color="#FF00BFFF"/>
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item>
                <bitmap android:src="@drawable/ic_zero" />
            </item>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="12dp"/>
                    <stroke android:width="2dp" android:color="#FF505050"/>
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
