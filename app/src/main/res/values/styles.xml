<?xml version="1.0" encoding="utf-8"?>
<resources>
    
    <style name="Theme.DRO" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">@color/coord_d</item>
        <item name="colorAccent">@color/coord_x</item>
        <item name="android:statusBarColor">@color/bg_darker</item>
        <item name="android:navigationBarColor">@color/bg_darker</item>
        <item name="android:windowBackground">@color/bg_dark</item>
    </style>

    <!-- Coordinate display styles - OPTIMIZED FOR DIGMA PLANE 9.7 3G (1024x768) -->
    <style name="CoordinateLabel">
        <item name="android:layout_width">70dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">40sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
    </style>

    <!-- МАКСИМАЛЬНЫЙ РАЗМЕР КООРДИНАТ - 110sp с контуром -->
    <style name="CoordinateValue">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">110sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="CoordinateMode">
        <item name="android:layout_width">50dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
    </style>

    <!-- Кнопки обнуления и установки - жёлтый текст -->
    <style name="ZeroButton">
        <item name="android:layout_width">120dp</item>
        <item name="android:layout_height">100dp</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:background">@drawable/button_zero</item>
    </style>

    <!-- Кнопки инструментов с подсветкой выбранного -->
    <style name="ToolButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">80dp</item>
        <item name="android:textSize">26sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:background">@drawable/button_tool</item>
    </style>

    <!-- Кнопки быстрого ввода в диалоге -->
    <style name="PresetButton">
        <item name="android:layout_width">60dp</item>
        <item name="android:layout_height">50dp</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_bright</item>
        <item name="android:background">@drawable/button_zero</item>
    </style>

</resources>
