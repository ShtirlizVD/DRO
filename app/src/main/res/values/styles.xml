<?xml version="1.0" encoding="utf-8"?>
<resources>
    
    <style name="Theme.DRO" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor">@color/bg_darker</item>
        <item name="android:navigationBarColor">@color/bg_darker</item>
        <item name="android:windowBackground">@color/bg_dark</item>
    </style>

    <!-- Coordinate display styles - OPTIMIZED FOR DIGMA PLANE 9.7 3G (1024x768) -->
    <style name="CoordinateLabel">
        <item name="android:layout_width">70dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">36sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
    </style>

    <!-- МАКСИМАЛЬНЫЙ РАЗМЕР КООРДИНАТ для планшета -->
    <style name="CoordinateValue">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">96sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:shadowColor">@color/black</item>
        <item name="android:shadowDx">3</item>
        <item name="android:shadowDy">3</item>
        <item name="android:shadowRadius">4</item>
    </style>

    <style name="CoordinateMode">
        <item name="android:layout_width">50dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
    </style>

    <!-- УВЕЛИЧЕННЫЕ КНОПКИ ОБНУЛЕНИЯ для планшета -->
    <style name="ZeroButton">
        <item name="android:layout_width">110dp</item>
        <item name="android:layout_height">90dp</item>
        <item name="android:textSize">32sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:background">@drawable/button_zero</item>
    </style>

    <!-- УВЕЛИЧЕННЫЕ КНОПКИ ИНСТРУМЕНТОВ для планшета -->
    <style name="ToolButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">80dp</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:background">@drawable/button_tool</item>
    </style>

</resources>
