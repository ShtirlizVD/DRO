<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.dro.lathe"
    android:versionCode="1"
    android:versionName="1.0" >

    <uses-sdk
        android:minSdkVersion="17"
        android:targetSdkVersion="34" />

    <!-- Bluetooth permissions -->
    <uses-permission android:name="android.permission.BLUETOOTH" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Keep screen on -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <uses-feature
        android:name="android.hardware.bluetooth"
        android:required="true" />

    <permission
        android:name="com.dro.lathe.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.dro.lathe.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION" />

    <application
        android:allowBackup="true"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:debuggable="true"
        android:extractNativeLibs="true"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/ic_launcher_foreground"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_launcher_foreground"
        android:supportsRtl="true"
        android:testOnly="true"
        android:theme="@style/Theme.DRO" >
        <activity
            android:name="com.dro.lathe.MainActivity"
            android:exported="true"
            android:keepScreenOn="true"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.DRO" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name="com.dro.lathe.SettingsActivity"
            android:exported="false"
            android:label="@string/settings"
            android:theme="@style/Theme.DRO" />
        <activity
            android:name="com.dro.lathe.ThreadHelperActivity"
            android:exported="false"
            android:label="@string/thread_helper"
            android:theme="@style/Theme.DRO" />
        <activity
            android:name="com.dro.lathe.AngleActivity"
            android:exported="false"
            android:label="@string/angle_measurement"
            android:theme="@style/Theme.DRO" />
        <activity
            android:name="com.dro.lathe.MarkerListActivity"
            android:exported="false"
            android:label="@string/marker_list"
            android:theme="@style/Theme.DRO" />
        <activity
            android:name="com.dro.lathe.ThreadDetailActivity"
            android:exported="false"
            android:label="@string/thread_detail"
            android:theme="@style/Theme.DRO" />

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="com.dro.lathe.androidx-startup"
            android:exported="false" >
            <meta-data
                android:name="androidx.emoji2.text.EmojiCompatInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.lifecycle.ProcessLifecycleInitializer"
                android:value="androidx.startup" />
        </provider>

        <uses-library
            android:name="androidx.window.extensions"
            android:required="false" />
        <uses-library
            android:name="androidx.window.sidecar"
            android:required="false" />
    </application>

</manifest>