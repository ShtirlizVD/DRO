<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@color/bg_darker"
    android:padding="12dp"
    android:gravity="center_vertical">

    <!-- Axis -->
    <TextView
        android:id="@+id/tv_axis"
        android:layout_width="40dp"
        android:layout_height="wrap_content"
        android:text="X"
        android:textColor="@color/coord_x"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center" />

    <!-- Name & Position -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/tv_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Marker Name"
            android:textColor="@color/text_bright"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tv_position"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="123.456"
            android:textColor="@color/text_dim"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Distance -->
    <TextView
        android:id="@+id/tv_distance"
        android:layout_width="80dp"
        android:layout_height="wrap_content"
        android:text="Δ 0.000"
        android:textColor="@color/text_bright"
        android:textSize="14sp"
        android:gravity="end" />

    <!-- Delete Button -->
    <Button
        android:id="@+id/btn_delete"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:text="×"
        android:textSize="20sp"
        android:background="@drawable/button_menu"
        android:layout_marginStart="8dp" />

</LinearLayout>
