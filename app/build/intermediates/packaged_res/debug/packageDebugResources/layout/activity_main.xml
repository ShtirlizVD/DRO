<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@color/bg_dark"
    tools:context=".MainActivity">

    <!-- Left Panel: Coordinates -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="8dp">

        <!-- X Coordinate Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/bg_darker"
            android:padding="4dp">

            <LinearLayout
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/label_x"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/coord_x"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/coord_x" />

                <TextView
                    android:id="@+id/mode_x"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/coord_x" />
            </LinearLayout>

            <TextView
                android:id="@+id/value_x"
                style="@style/CoordinateValue"
                android:layout_weight="1"
                android:textColor="@color/coord_x"
                android:text="000.000" />

            <Button
                android:id="@+id/btn_zero_x"
                style="@style/ZeroButton"
                android:text="0"
                android:textColor="@color/coord_x" />
        </LinearLayout>

        <!-- D Coordinate Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/bg_darker"
            android:padding="4dp"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/label_d"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="@string/coord_d"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/coord_d"
                android:gravity="center" />

            <TextView
                android:id="@+id/value_d"
                style="@style/CoordinateValue"
                android:layout_weight="1"
                android:textColor="@color/coord_d"
                android:text="000.000" />

            <Button
                android:id="@+id/btn_set_d"
                style="@style/ZeroButton"
                android:text="Ø"
                android:textColor="@color/coord_d" />
        </LinearLayout>

        <!-- Z Coordinate Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/bg_darker"
            android:padding="4dp"
            android:layout_marginTop="4dp">

            <LinearLayout
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/label_z"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/coord_z"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/coord_z" />
            </LinearLayout>

            <TextView
                android:id="@+id/value_z"
                style="@style/CoordinateValue"
                android:layout_weight="1"
                android:textColor="@color/coord_z"
                android:text="000.000" />

            <Button
                android:id="@+id/btn_zero_z"
                style="@style/ZeroButton"
                android:text="0"
                android:textColor="@color/coord_z" />
        </LinearLayout>

        <!-- L Coordinate Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/bg_darker"
            android:padding="4dp"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/label_l"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="@string/coord_l"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/coord_l"
                android:gravity="center" />

            <TextView
                android:id="@+id/value_l"
                style="@style/CoordinateValue"
                android:layout_weight="1"
                android:textColor="@color/coord_l"
                android:text="000.000" />

            <Button
                android:id="@+id/btn_set_l"
                style="@style/ZeroButton"
                android:text="L"
                android:textColor="@color/coord_l" />
        </LinearLayout>

        <!-- Status Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="4dp"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tv_tool"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Инстр. 1"
                android:textColor="@color/text_bright"
                android:textSize="12sp"
                android:background="@drawable/button_menu"
                android:padding="4dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/disconnected"
                android:textColor="@color/status_disconnected"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_connect"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/connect"
                android:textSize="12sp"
                android:background="@drawable/button_menu" />
        </LinearLayout>
    </LinearLayout>

    <!-- Right Panel: Tools & Menu -->
    <LinearLayout
        android:layout_width="180dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="8dp"
        android:background="@color/bg_darker">

        <!-- Tools -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/tool"
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            android:gravity="center"
            android:paddingBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_tool_1"
                style="@style/ToolButton"
                android:layout_weight="1"
                android:layout_margin="2dp"
                android:text="1"
                android:textColor="@color/text_bright" />

            <Button
                android:id="@+id/btn_tool_2"
                style="@style/ToolButton"
                android:layout_weight="1"
                android:layout_margin="2dp"
                android:text="2"
                android:textColor="@color/text_bright" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_tool_3"
                style="@style/ToolButton"
                android:layout_weight="1"
                android:layout_margin="2dp"
                android:text="3"
                android:textColor="@color/text_bright" />

            <Button
                android:id="@+id/btn_tool_4"
                style="@style/ToolButton"
                android:layout_weight="1"
                android:layout_margin="2dp"
                android:text="4"
                android:textColor="@color/text_bright" />
        </LinearLayout>

        <!-- Menu Buttons -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/button_border"
            android:layout_marginVertical="8dp" />

        <Button
            android:id="@+id/btn_markers"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="@string/marker_list"
            android:textColor="@color/text_bright"
            android:background="@drawable/button_menu"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <Button
            android:id="@+id/btn_thread"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="@string/thread_helper"
            android:textColor="@color/text_bright"
            android:background="@drawable/button_menu"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <Button
            android:id="@+id/btn_angle"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="@string/angle_measurement"
            android:textColor="@color/text_bright"
            android:background="@drawable/button_menu"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btn_settings"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="@string/settings"
            android:textColor="@color/text_bright"
            android:background="@drawable/button_menu"
            android:textSize="12sp" />
    </LinearLayout>

</LinearLayout>
