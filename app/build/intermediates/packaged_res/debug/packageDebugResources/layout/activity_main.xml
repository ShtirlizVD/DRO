<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <!-- Left Panel: Coordinates (MAXIMIZED) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="10dp">

            <!-- X Coordinate Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/bg_darker"
                android:padding="8dp">

                <LinearLayout
                    android:layout_width="70dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/label_x"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/coord_x"
                        android:textSize="40sp"
                        android:textStyle="bold"
                        android:textColor="@color/coord_x" />

                    <ImageView
                        android:id="@+id/img_mode"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@drawable/ic_diameter"
                        android:contentDescription="Mode" />
                </LinearLayout>

                <com.dro.lathe.StrokeTextView
                    android:id="@+id/value_x"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/coord_x"
                    android:text="000.000"
                    android:textSize="110sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:includeFontPadding="false" />

                <androidx.cardview.widget.CardView
                    android:id="@+id/btn_zero_x"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardPreventCornerOverlap="false"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/frame_selector">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_zero"
                        android:scaleType="centerCrop"
                        android:contentDescription="Zero X" />
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- D Coordinate Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/bg_darker"
                android:padding="8dp"
                android:layout_marginTop="6dp">

                <TextView
                    android:id="@+id/label_d"
                    android:layout_width="70dp"
                    android:layout_height="wrap_content"
                    android:text="@string/coord_d"
                    android:textSize="40sp"
                    android:textStyle="bold"
                    android:textColor="@color/coord_d"
                    android:gravity="center" />

                <com.dro.lathe.StrokeTextView
                    android:id="@+id/value_d"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/coord_d"
                    android:text="000.000"
                    android:textSize="110sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:includeFontPadding="false" />

                <androidx.cardview.widget.CardView
                    android:id="@+id/btn_set_d"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardPreventCornerOverlap="false"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/frame_selector">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_diameter2"
                        android:scaleType="centerCrop"
                        android:contentDescription="Set Diameter" />
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Z Coordinate Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/bg_darker"
                android:padding="8dp"
                android:layout_marginTop="6dp">

                <LinearLayout
                    android:layout_width="70dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/label_z"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/coord_z"
                        android:textSize="40sp"
                        android:textStyle="bold"
                        android:textColor="@color/coord_z" />
                </LinearLayout>

                <com.dro.lathe.StrokeTextView
                    android:id="@+id/value_z"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/coord_z"
                    android:text="000.000"
                    android:textSize="110sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:includeFontPadding="false" />

                <androidx.cardview.widget.CardView
                    android:id="@+id/btn_zero_z"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardPreventCornerOverlap="false"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/frame_selector">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_zero"
                        android:scaleType="centerCrop"
                        android:contentDescription="Zero Z" />
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- L Coordinate Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/bg_darker"
                android:padding="8dp"
                android:layout_marginTop="6dp">

                <TextView
                    android:id="@+id/label_l"
                    android:layout_width="70dp"
                    android:layout_height="wrap_content"
                    android:text="@string/coord_l"
                    android:textSize="40sp"
                    android:textStyle="bold"
                    android:textColor="@color/coord_l"
                    android:gravity="center" />

                <com.dro.lathe.StrokeTextView
                    android:id="@+id/value_l"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/coord_l"
                    android:text="000.000"
                    android:textSize="110sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:includeFontPadding="false" />

                <androidx.cardview.widget.CardView
                    android:id="@+id/btn_set_l"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardPreventCornerOverlap="false"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/frame_selector">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_length"
                        android:scaleType="centerCrop"
                        android:contentDescription="Set Length" />
                </androidx.cardview.widget.CardView>
            </LinearLayout>

        </LinearLayout>

        <!-- Right Panel: Tools & Menu -->
        <LinearLayout
            android:layout_width="200dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="8dp"
            android:background="@color/bg_darker">

            <!-- Tool Button with icon -->
            <ImageButton
                android:id="@+id/btn_tool"
                android:layout_width="match_parent"
                android:layout_height="95dp"
                android:src="@drawable/ic_tool_1"
                android:scaleType="fitCenter"
                android:background="@drawable/button_tool_main"
                android:contentDescription="Выбор инструмента"
                android:padding="0dp" />

            <!-- Absolute Coordinates Display -->
            <LinearLayout
                android:id="@+id/abs_coords_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="6dp"
                android:background="@drawable/dialog_background"
                android:padding="6dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ABS"
                    android:textColor="@color/text_dim"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="X:"
                        android:textColor="@color/coord_x"
                        android:textSize="34sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_abs_x"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="0.00"
                        android:textColor="@color/coord_x"
                        android:textSize="34sp"
                        android:gravity="end"
                        android:longClickable="true" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="2dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Z:"
                        android:textColor="@color/coord_z"
                        android:textSize="34sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_abs_z"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="0.00"
                        android:textColor="@color/coord_z"
                        android:textSize="34sp"
                        android:gravity="end"
                        android:longClickable="true" />
                </LinearLayout>
            </LinearLayout>

            <!-- Menu Buttons -->
            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@color/bg_dark"
                android:layout_marginTop="8dp" />

            <!-- Markers Button -->
            <Button
                android:id="@+id/btn_markers"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/marker_list"
                android:textColor="@color/text_bright"
                android:background="@drawable/button_menu"
                android:textSize="15sp"
                android:layout_marginTop="6dp" />

            <!-- Active Markers List -->
            <LinearLayout
                android:id="@+id/active_markers_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="4dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_active_markers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_dim"
                    android:textSize="12sp"
                    android:padding="4dp"
                    android:gravity="center" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Bottom Buttons -->
            <Button
                android:id="@+id/btn_ball"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Шар"
                android:textColor="@color/text_bright"
                android:background="@drawable/button_menu"
                android:textSize="15sp"
                android:layout_marginBottom="6dp" />

            <Button
                android:id="@+id/btn_thread"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/thread_helper"
                android:textColor="@color/text_bright"
                android:background="@drawable/button_menu"
                android:textSize="15sp"
                android:layout_marginBottom="6dp" />

            <Button
                android:id="@+id/btn_angle"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/angle_measurement"
                android:textColor="@color/text_bright"
                android:background="@drawable/button_menu"
                android:textSize="15sp"
                android:layout_marginBottom="6dp" />

            <Button
                android:id="@+id/btn_settings"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/settings"
                android:textColor="@color/text_bright"
                android:background="@drawable/button_menu"
                android:textSize="15sp" />
        </LinearLayout>

    </LinearLayout>

    <!-- Connect Button Overlay (center of screen) -->
    <Button
        android:id="@+id/btn_connect_overlay"
        android:layout_width="300dp"
        android:layout_height="80dp"
        android:layout_gravity="center"
        android:text="@string/connect"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/text_bright"
        android:background="@drawable/button_menu"
        android:visibility="visible" />

</FrameLayout>
