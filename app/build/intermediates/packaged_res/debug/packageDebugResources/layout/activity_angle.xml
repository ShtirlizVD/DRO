<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    android:padding="16dp">

    <!-- Current position -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/bg_darker"
        android:padding="8dp"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Текущая позиция:  "
            android:textColor="@color/text_dim"
            android:textSize="12sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="X:"
            android:textColor="@color/coord_x"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tv_current_x"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.00"
            android:textColor="@color/text_bright"
            android:textSize="14sp"
            android:layout_marginEnd="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Z:"
            android:textColor="@color/coord_z"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tv_current_z"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.00"
            android:textColor="@color/text_bright"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Start Point -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="16dp"
        android:background="@color/bg_darker"
        android:padding="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/start_point"
            android:textColor="@color/text_bright"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="30dp"
                android:layout_height="wrap_content"
                android:text="@string/coord_x"
                android:textColor="@color/coord_x"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tv_start_x"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="—"
                android:textColor="@color/text_bright"
                android:textSize="20sp" />

            <TextView
                android:layout_width="30dp"
                android:layout_height="wrap_content"
                android:text="@string/coord_z"
                android:textColor="@color/coord_z"
                android:textSize="16sp"
                android:layout_marginStart="16dp" />

            <TextView
                android:id="@+id/tv_start_z"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="—"
                android:textColor="@color/text_bright"
                android:textSize="20sp" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_set_start"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:text="Запомнить"
            android:textColor="@color/text_bright"
            android:background="@drawable/button_menu" />
    </LinearLayout>

    <!-- End Point -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="8dp"
        android:background="@color/bg_darker"
        android:padding="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/end_point"
            android:textColor="@color/text_bright"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="30dp"
                android:layout_height="wrap_content"
                android:text="@string/coord_x"
                android:textColor="@color/coord_x"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tv_end_x"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="—"
                android:textColor="@color/text_bright"
                android:textSize="20sp" />

            <TextView
                android:layout_width="30dp"
                android:layout_height="wrap_content"
                android:text="@string/coord_z"
                android:textColor="@color/coord_z"
                android:textSize="16sp"
                android:layout_marginStart="16dp" />

            <TextView
                android:id="@+id/tv_end_z"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="—"
                android:textColor="@color/text_bright"
                android:textSize="20sp" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_set_end"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:text="Запомнить"
            android:textColor="@color/text_bright"
            android:background="@drawable/button_menu" />
    </LinearLayout>

    <!-- Result -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="16dp"
        android:background="@color/bg_darker"
        android:padding="16dp"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Угол к оси Z"
            android:textColor="@color/text_dim"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tv_angle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—°"
            android:textColor="@color/coord_l"
            android:textSize="48sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Расстояние: "
                android:textColor="@color/text_dim"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/text_bright"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_reset"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="Сброс"
            android:textColor="@color/text_bright"
            android:background="@drawable/button_menu"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btn_close"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="Закрыть"
            android:textColor="@color/text_bright"
            android:background="@drawable/button_menu" />
    </LinearLayout>

</LinearLayout>
