<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    android:padding="16dp">

    <!-- Tabs -->
    <LinearLayout
        android:id="@+id/tabs_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/tab_metric"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="Метр."
            android:textSize="12sp"
            android:background="@drawable/button_tool" />

        <Button
            android:id="@+id/tab_inch"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="Дюйм."
            android:textSize="12sp"
            android:background="@drawable/button_tool"
            android:layout_marginStart="4dp" />

        <Button
            android:id="@+id/tab_pipe"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="Труб."
            android:textSize="12sp"
            android:background="@drawable/button_tool"
            android:layout_marginStart="4dp" />
    </LinearLayout>

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:layout_marginTop="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Резьба"
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="70dp"
            android:layout_height="wrap_content"
            android:text="Шаг"
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:layout_width="70dp"
            android:layout_height="wrap_content"
            android:text="Глубина"
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:text="Прох."
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center" />
    </LinearLayout>

    <!-- List -->
    <ListView
        android:id="@+id/thread_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/bg_darker"
        android:divider="@color/button_border"
        android:dividerHeight="1dp" />

    <Button
        android:id="@+id/btn_close"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="8dp"
        android:text="Закрыть"
        android:textColor="@color/text_bright"
        android:background="@drawable/button_menu" />

</LinearLayout>
