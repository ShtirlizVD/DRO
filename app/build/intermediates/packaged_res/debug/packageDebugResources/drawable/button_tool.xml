<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="#FF3D5A3D"/>
            <corners android:radius="8dp"/>
            <stroke android:width="3dp" android:color="#FF00FF00"/>
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#FF404040"/>
            <corners android:radius="8dp"/>
            <stroke android:width="2dp" android:color="#FF606060"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FF2D2D2D"/>
            <corners android:radius="8dp"/>
            <stroke android:width="2dp" android:color="#FF404040"/>
        </shape>
    </item>
</selector>
